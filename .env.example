# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Base URL of the API gateway. gatewayUrl(path) resolves against this.
# Points at the Go gacha backend (make run / make dev on :9090).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:9090/api/

# Auth.js v5 secret, used for JWT/session encryption.
# Generate one with:  npx auth secret   (or)   openssl rand -base64 32
AUTH_SECRET=
